{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "web-portofilo",
  "compatibility_date": "2026-04-06",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [
      ".git",
      ".playwright-mcp",
      ".superpowers",
      "docs",
      "memory",
      ".claude",
      "README.md",
      "wrangler.jsonc"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
